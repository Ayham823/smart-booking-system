@model IEnumerable<SmartBookingSystem.Models.Coach>

@{
    ViewData["Title"] = "Coaches";
}

<h1>Coaches</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create Coach</a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Specialty</th>
            <th>Bio</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.User?.FullName</td>
                <td>@item.User?.Email</td>
                <td>@item.Specialty</td>
                <td>@item.Bio</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="text-success">🟢 Active</span>
                    }
                    else
                    {
                        <span class="text-danger">🔴 Inactive</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>

                        @if (item.IsActive)
                        {
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <a asp-action="Activate" asp-route-id="@item.Id" class="btn btn-success btn-sm">Activate</a>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

