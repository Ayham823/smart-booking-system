@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Smart Booking System</h1>
    <p class="lead">Training Center Booking and Management Platform</p>
</div>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card p-3 h-100">
            <h4>Training Services</h4>
            <p>Browse available training services and courses.</p>
            <a asp-controller="TrainingServices" asp-action="Index" class="btn btn-primary">View Services</a>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card p-3 h-100">
            <h4>Book Appointment</h4>
            <p>Choose a coach, date, and available time slot.</p>
            <a asp-controller="Appointments" asp-action="Book" class="btn btn-success">Book Now</a>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card p-3 h-100">
            <h4>Dashboard</h4>
            <p>Open your dashboard based on your role.</p>
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-dark">Open Dashboard</a>
        </div>
    </div>
</div>
