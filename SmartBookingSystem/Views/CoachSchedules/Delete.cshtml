@model SmartBookingSystem.Models.CoachSchedule

@{
    ViewData["Title"] = "Delete Schedule";
}

<h1>Delete Schedule</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Coach</dt>
        <dd class="col-sm-9">@Model.Coach?.User?.FullName</dd>

        <dt class="col-sm-3">Day</dt>
        <dd class="col-sm-9">@((DayOfWeek)Model.DayOfWeek)</dd>

        <dt class="col-sm-3">Start</dt>
        <dd class="col-sm-9">@Model.StartTime</dd>

        <dt class="col-sm-3">End</dt>
        <dd class="col-sm-9">@Model.EndTime</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>
