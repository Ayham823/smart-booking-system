@model IEnumerable<SmartBookingSystem.Models.CoachSchedule>

@{
    ViewData["Title"] = "Coach Schedules";
}

<h1>Coach Schedules</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create Schedule</a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Coach</th>
            <th>Day</th>
            <th>Start</th>
            <th>End</th>
            <th>Available</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Coach?.User?.FullName</td>
                <td>@((DayOfWeek)item.DayOfWeek)</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
                <td>@item.IsAvailable</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
