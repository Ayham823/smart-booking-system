@model SmartBookingSystem.Models.Appointment

@{
    ViewData["Title"] = "Cancel Appointment";
}

<h1>Cancel Appointment</h1>

<h3>Are you sure you want to cancel this appointment?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Service</dt>
        <dd class="col-sm-9">@Model.TrainingService?.Name</dd>

        <dt class="col-sm-3">Coach</dt>
        <dd class="col-sm-9">@Model.Coach?.User?.FullName</dd>

        <dt class="col-sm-3">Start</dt>
        <dd class="col-sm-9">@Model.StartDateTime</dd>

        <dt class="col-sm-3">End</dt>
        <dd class="col-sm-9">@Model.EndDateTime</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <form asp-action="Cancel" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirm Cancel</button>
        <a asp-action="MyAppointments" class="btn btn-secondary">Back</a>
    </form>
</div>
